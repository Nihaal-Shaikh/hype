# Copy this file to .env and fill in real values.
# .env is gitignored — the real secrets never leave your machine.

# Your main Hyperliquid wallet address (the one holding your USDC).
# This is PUBLIC information — addresses are not secret, only private keys are.
HL_MAIN_ADDRESS=0xYourMainWalletAddressHere

# Private key of your Hyperliquid API agent wallet — NOT your main wallet's key.
# Created via app.hyperliquid.xyz/API → Generate.
# This key can place and cancel orders but cannot withdraw funds.
# Keep it secret. Never commit this file. Never paste it in chat.
HL_AGENT_PRIVATE_KEY=0xYourAgentPrivateKeyHere

# Hyperliquid network. Set to "mainnet" or "testnet".
HL_NETWORK=mainnet
